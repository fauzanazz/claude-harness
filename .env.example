# Optional — defaults shown
# Uses local Claude CLI for authentication (no API key needed)
# MODEL=claude-sonnet-4-6
# SANDBOX_IMAGE=claude-harness-sandbox
# SANDBOX_MEMORY=2g
# SANDBOX_CPUS=1
# SANDBOX_TIMEOUT=3600

# Container pool
# POOL_MIN_SIZE=1
# POOL_MAX_SIZE=5

# Context compaction
# MAX_CONTEXT_TOKENS=100000
# COMPACTION_MODEL=claude-haiku-4-5-20251001

# Permissions
# PERMISSION_TIMEOUT=60

# Sandbox backend: "docker" (default) or "firecracker"
# SANDBOX_BACKEND=docker

# Firecracker settings (only used when SANDBOX_BACKEND=firecracker)
# FIRECRACKER_BIN=firecracker
# FIRECRACKER_KERNEL_PATH=firecracker/kernel/vmlinux
# FIRECRACKER_ROOTFS_PATH=firecracker/rootfs/rootfs.ext4
# FIRECRACKER_SNAPSHOT_PATH=firecracker/snapshot/base
